{% set pfx = pathPrefix %}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — {% endif %}Oracle 23ai Help Center</title>
<meta name="description" content="{{ description or 'Technical support, guides, and blog for Oracle Database 23ai.' }}">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ pfx }}/assets/css/main.css">
<link rel="stylesheet" href="{{ pfx }}/assets/css/articles.css">

<!-- Pagefind search UI -->
<link href="{{ pfx }}/pagefind/pagefind-ui.css" rel="stylesheet" onerror="this.remove()">
</head>
<body>

<nav>
  <a href="{{ pfx }}" class="nav-logo">
    <div class="nav-logo-icon">O</div>
    <div class="nav-logo-text">Oracle <span>23ai</span></div>
  </a>
  <ul class="nav-links">
    <li><a href="{{ pfx }}/support/">Support</a></li>
    <li><a href="{{ pfx }}/blog/">Blog</a></li>
    <li><a href="{{ pfx }}/install/">Install</a></li>
    <li><a href="{{ pfx }}/#versions">Versions</a></li>
    <li><a href="#" id="search-trigger" class="nav-search">⌕ Search</a></li>
  </ul>
</nav>

<!-- Rest of the template with all links using {{ pfx }} -->

<!-- Search overlay -->
<div id="search-overlay" class="search-overlay hidden">
  <div class="search-overlay-inner">
    <div id="search-widget"></div>
    <button class="search-close" onclick="closeSearch()">✕ Close</button>
  </div>
</div>

<main>
  {{ content | safe }}
</main>

<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="nav-logo" style="text-decoration:none; display:flex; align-items:center; gap:10px; margin-bottom:4px;">
        <div class="nav-logo-icon">O</div>
        <div class="nav-logo-text">Oracle <span>23ai</span></div>
      </div>
      <p>An independent technical help center and blog for Oracle Database 23ai developers, DBAs, and architects. Not affiliated with Oracle Corporation.</p>
    </div>
    <div class="footer-col">
      <div class="footer-col-title">INSTALL</div>
      <ul>
        <li><a href="{{ '/install/installing-oracle-23ai-free/' | url }}">Installation Guides</a></li>
        <li><a href="{{ '/install/' | url }}">Error Reference</a></li>
        <li><a href="{{ '/install/' | url }}">AI Features</a></li>
        <li><a href="{{ '/install/' | url }}">Performance</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <div class="footer-col-title">Blog</div>
      <ul>
        <li><a href="{{ '/blog/' | url }}">All Posts</a></li>
        <li><a href="{{ '/blog/' | url }}">Deep Dives</a></li>
        <li><a href="{{ '/blog/' | url }}">Tutorials</a></li>
        <li><a href="{{ '/blog/' | url }}">Migration</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <div class="footer-col-title">Resources</div>
      <ul>
        <li><a href="https://docs.oracle.com" target="_blank">Oracle Docs ↗</a></li>
        <li><a href="https://livesql.oracle.com" target="_blank">23ai Live SQL ↗</a></li>
        <li><a href="https://oracle.com/cloud/free" target="_blank">OCI Free Tier ↗</a></li>
        <li><a href="https://asktom.oracle.com" target="_blank">AskTOM ↗</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2025 Oracle 23ai Help Center — Independent resource. Oracle® is a registered trademark of <span>Oracle Corporation</span>.</p>
  </div>
</footer>

<script src="{{ '/pagefind/pagefind-ui.js' | url }}" onerror="this.remove()"></script>
<script>
  // Pagefind search widget
  if (window.PagefindUI) {
    new PagefindUI({ element: "#search-widget", showSubResults: true });
  }
  document.getElementById('search-trigger')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('search-overlay').classList.remove('hidden');
    document.querySelector('.pagefind-ui__search-input')?.focus();
  });
  function closeSearch() {
    document.getElementById('search-overlay').classList.add('hidden');
  }
  document.getElementById('search-overlay')?.addEventListener('click', (e) => {
    if (e.target.id === 'search-overlay') closeSearch();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('search-overlay').classList.remove('hidden');
    }
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.1 });
  reveals.forEach(r => observer.observe(r));
</script>
</body>
</html>