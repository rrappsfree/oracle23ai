<!-- HERO -->
<meta name="google-site-verification" content="DLIajZKqPURks7gOJEJ6F2FZA6L3agRSO3TieWD_OMU" />
<section class="hero">
  <div class="hero-bg-grid"></div>
  <div class="hero-left">
    <div class="hero-eyebrow">Oracle 23ai Help Center</div>
    <h1>Your AI-Native<br>Database <em>Guide</em></h1>
    <p class="hero-desc">Comprehensive technical support, tutorials, and insights for Oracle Database 23ai — the first AI-native database from Oracle.</p>
    <div class="hero-actions">
      <a href="{{'/support/' | url }}" class="btn-primary">Browse Support</a>
      <a href="{{ '/blog/' | url }}" class="btn-ghost">Read the Blog</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-terminal">
      <div class="terminal-bar">
        <div class="dot dot-r"></div>
        <div class="dot dot-y"></div>
        <div class="dot dot-g"></div>
        <div class="terminal-title">oracle23ai — sqlplus</div>
      </div>
      <div class="terminal-body">
        <div><span class="t-comment">-- Oracle Database 23ai</span></div>
        <div><span class="t-comment">-- AI Vector Search Example</span></div>
        <div>&nbsp;</div>
        <div><span class="t-prompt">SQL&gt; </span><span class="t-keyword">CREATE TABLE</span><span class="t-cmd"> docs (</span></div>
        <div><span class="t-cmd">&nbsp;&nbsp;&nbsp;id&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;NUMBER,</span></div>
        <div><span class="t-cmd">&nbsp;&nbsp;&nbsp;content </span><span class="t-keyword">CLOB</span><span class="t-cmd">,</span></div>
        <div><span class="t-cmd">&nbsp;&nbsp;&nbsp;embed&nbsp;&nbsp;&nbsp;</span><span class="t-keyword">VECTOR</span><span class="t-cmd">(1536)</span></div>
        <div><span class="t-cmd">);</span></div>
        <div>&nbsp;</div>
        <div><span class="t-output">Table created.</span></div>
        <div>&nbsp;</div>
        <div><span class="t-prompt">SQL&gt; </span><span class="t-keyword">SELECT</span><span class="t-cmd"> id, </span><span class="t-keyword">VECTOR_DISTANCE</span></div>
        <div><span class="t-cmd">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(embed, :query_vec)</span></div>
        <div><span class="t-keyword">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;FROM</span><span class="t-cmd"> docs</span></div>
        <div><span class="t-keyword">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ORDER BY</span><span class="t-cmd"> 2 </span><span class="t-keyword">FETCH FIRST</span><span class="t-cmd"> 5 </span><span class="t-keyword">ROWS ONLY</span><span class="t-cmd">;</span></div>
        <div>&nbsp;</div>
        <div><span class="t-prompt">SQL&gt; </span><span class="t-cursor"></span></div>
