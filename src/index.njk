<script>
  // Search tags
  document.querySelectorAll('.search-tag').forEach(tag => {
    tag.addEventListener('click', () => {
      document.getElementById('hero-search').value = tag.textContent;
    });
  });

  // Trigger Pagefind search overlay
  function triggerSearch() {
    const val = document.getElementById('hero-search').value;
    document.getElementById('search-overlay').classList.remove('hidden');
    setTimeout(() => {
      const input = document.querySelector('.pagefind-ui__search-input');
      if (input) { input.value = val; input.dispatchEvent(new Event('input')); }
    }, 100);
  }

  document.getElementById('hero-search').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') triggerSearch();
  });
</script>
