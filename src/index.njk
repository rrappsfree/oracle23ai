<!-- SUPPORT -->
<section id="support" class="reveal">
  <div class="section-header">
    <div>
      <div class="section-label">// Technical Support</div>
      <h2>Find Your Answer</h2>
    </div>
    <a href="{{'/support/' | url }}" class="see-all">View All Articles →</a>
  </div>

  <div class="support-grid">

    <!-- Pinned: New Features article -->
    {% for post in collections.posts %}
      {% if post.data.featured %}
      <a href="{{ post.url | url }}" class="support-card">
        <div class="card-icon">🚀</div>
        <div class="card-tag">New Features</div>
        <div class="card-title">{{ post.data.title }}</div>
        <div class="card-desc">{{ post.data.description }}</div>
        <div class="card-meta">
          <span class="card-badge badge-new">New</span>
          <span class="card-badge badge-info">{{ post.data.readTime }}</span>
        </div>
      </a>
      {% endif %}
    {% endfor %}
    
    <!-- Pinned: 19c vs 23ai differences -->
    <a href="{{'/posts/oracle-19c-vs-23ai-differences/' | url}}" class="support-card">
      <div class="card-icon">🔄</div>
      <div class="card-tag">Comparison</div>
      <div class="card-title">Key Differences Between Oracle 19c and 23ai</div>
      <div class="card-desc">A detailed side-by-side comparison across AI, SQL, security, performance, architecture, and support lifecycle to help you decide when to upgrade.</div>
      <div class="card-meta">
        <span class="card-badge badge-updated">Updated</span>
        <span class="card-badge badge-info">14 min read</span>
      </div>
    </a>
    
    
  
    {% for article in collections.support | limit(6) %}
    <a href="{{ article.url | url }}" class="support-card">
      <div class="card-icon">📄</div>
      <div class="card-tag">{{ article.data.tag }}</div>
      <div class="card-title">{{ article.data.title }}</div>
      <div class="card-desc">{{ article.data.description }}</div>
      <div class="card-meta">
        {% if article.data.difficulty %}
          <span class="card-badge badge-{{ article.data.difficulty }}">{{ article.data.difficulty }}</span>
        {% endif %}
        {% if article.data.readTime %}
          <span class="card-badge badge-info">{{ article.data.readTime }}</span>
        {% endif %}
      </div>
    </a>
    {% else %}
    <p style="color: var(--text-muted); font-family: var(--mono); padding: 32px;">No support articles yet. Add Markdown files to src/support/</p>
    {% endfor %}
  </div>
</section>

<!-- BLOG -->
<section id="blog" class="reveal" style="background: var(--surface);">
  <div class="section-header">
    <div>
      <div class="section-label">// Blog & Insights</div>
      <h2>Latest from the Field</h2>
    </div>
    <a href="{{'/blog/' | url }}" class="see-all">All Posts →</a>
  </div>
  
  <div class="blog-layout">
    {% set featuredPost = collections.posts | selectattr("data.featured") | first %}
    {% if not featuredPost %}{% set featuredPost = collections.posts | first %}{% endif %}
    {% if featuredPost %}
    <a href="{{ featuredPost.url | url }}" class="blog-featured">
      <div class="blog-featured-img">
        <div class="blog-featured-img-inner">23ai</div>
        <div class="version-badge">{{ featuredPost.data.tag }} · {{ featuredPost.date | readableDate }}</div>
      </div>
      <div class="blog-featured-body">
        <div class="post-category">{{ featuredPost.data.tag }}</div>
        <div class="post-title">{{ featuredPost.data.title }}</div>
        <p class="post-excerpt">{{ featuredPost.data.description }}</p>
        <div class="post-meta">
          <span class="post-author">{{ featuredPost.data.author }}</span>
          <span>{{ featuredPost.date | readableDate }}</span>
          <span>{{ featuredPost.data.readTime }}</span>
        </div>
      </div>
    </a>
    {% endif %}

    <div class="blog-list">
      {% for post in collections.posts | limit(5) %}
      <a href="{{ post.url | url }}" class="blog-list-item">
        <div class="card-tag" style="font-size:10px; margin-bottom:6px;">{{ post.data.tag }}</div>
        <div class="list-post-title">{{ post.data.title }}</div>
        <div class="list-post-meta">
          <span>{{ post.date | readableDate }}</span>
          <span>{{ post.data.readTime }}</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

