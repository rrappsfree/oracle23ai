<!-- SEARCH -->
<div class="search-section">
  <div class="search-label">// Search the knowledge base</div>
  <div class="search-bar">
    <span class="search-icon">⌕</span>
    <input type="text" placeholder="Search docs, errors, how-tos..." id="hero-search">
